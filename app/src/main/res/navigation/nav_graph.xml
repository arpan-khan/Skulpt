<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.skulpt.app.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">

        <action
            android:id="@+id/action_dashboard_to_workoutSession"
            app:destination="@id/workoutSessionFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_dashboard_to_customDay"
            app:destination="@id/customDayFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/workoutSessionFragment"
        android:name="com.skulpt.app.ui.session.WorkoutSessionFragment"
        android:label="Workout"
        tools:layout="@layout/fragment_workout_session">
        <argument
            android:name="dayId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/customDayFragment"
        android:name="com.skulpt.app.ui.custom.CustomDayFragment"
        android:label="Custom Day"
        tools:layout="@layout/fragment_custom_day" />

    <fragment
        android:id="@+id/statsFragment"
        android:name="com.skulpt.app.ui.stats.StatsFragment"
        android:label="Stats"
        tools:layout="@layout/fragment_stats" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.skulpt.app.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
